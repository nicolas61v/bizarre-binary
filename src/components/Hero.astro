---
import { createReader } from "@keystatic/core/reader";
import keystaticConfig from "../../keystatic.config";

const reader = createReader(process.cwd(), keystaticConfig);
const heroContent = await reader.singletons.hero.read();

const heroSubtitle = heroContent?.subtitle || "Dejavu Estudios";
const heroTagline = heroContent?.tagline || "Studio de Modelaje Webcam";
const heroTitle = heroContent?.title || "Tu Belleza, Tu Poder";
---

<section class="hero" id="inicio">
    <!-- Background -->
    <div class="hero__bg">
        <video
            class="hero__video"
            autoplay
            muted
            loop
            playsinline
            preload="auto"
            aria-hidden="true"
        >
            <source src="/VIDEO/hero-Bg.mp4" type="video/mp4" />
        </video>
        <div class="hero__bg-gradient"></div>
        <div class="hero__bokeh hero__bokeh--1"></div>
        <div class="hero__bokeh hero__bokeh--2"></div>
        <div class="hero__bokeh hero__bokeh--3"></div>
        <div class="hero__bokeh hero__bokeh--4"></div>
        <div class="hero__bokeh hero__bokeh--5"></div>
    </div>

    <!-- Particles -->
    <div class="hero__particles" aria-hidden="true">
        <span class="particle particle--1"></span>
        <span class="particle particle--2"></span>
        <span class="particle particle--3"></span>
        <span class="particle particle--4"></span>
        <span class="particle particle--5"></span>
        <span class="particle particle--6"></span>
        <span class="particle particle--7"></span>
        <span class="particle particle--8"></span>
        <span class="particle particle--9"></span>
        <span class="particle particle--10"></span>
        <span class="particle particle--11"></span>
        <span class="particle particle--12"></span>
    </div>

    <!-- Content -->
    <div class="hero__content container">
        <div class="hero__card-line"></div>
        <p class="hero__subtitle">{heroSubtitle}</p>
        <h1 class="hero__title">{heroTitle}</h1>
        <p class="hero__tagline">{heroTagline}</p>
        <p class="hero__description">
            Maximiza tus ingresos con el respaldo de un equipo profesional.
            Estrategia, herramientas y acompañamiento para que ganes más.
        </p>
        <div class="hero__actions">
            <a href="#contacto" class="hero__btn hero__btn--primary">
                <span>Empieza a Ganar</span>
                <svg
                    width="16"
                    height="16"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                >
                    <path d="M5 12h14M12 5l7 7-7 7"></path>
                </svg>
            </a>
            <a href="#servicios" class="hero__btn hero__btn--secondary">
                Conoce Más
            </a>
        </div>
    </div>

    <!-- Scroll Indicator -->
    <div class="hero__scroll" aria-hidden="true">
        <span class="hero__scroll-text">Scroll</span>
        <div class="hero__scroll-line">
            <div class="hero__scroll-dot"></div>
        </div>
    </div>
</section>

<script>
    const video = document.querySelector<HTMLVideoElement>(".hero__video");
    const hero  = document.querySelector<HTMLElement>("#inicio");

    if (video && hero) {
        const observer = new IntersectionObserver(
            ([entry]) => {
                if (entry.isIntersecting) {
                    video.play().catch(() => {});
                } else {
                    video.pause();
                }
            },
            { threshold: 0.1 }   // pausa cuando menos del 10% del hero es visible
        );
        observer.observe(hero);
    }
</script>

<style>
    /* ═══════════════════════════════════════════
     HERO SECTION
    ═══════════════════════════════════════════ */
    .hero {
        position: relative;
        width: 100%;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
    }

    /* ─── Background ─── */
    .hero__bg {
        position: absolute;
        inset: 0;
        z-index: 0;
    }

    .hero__video {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    @media (prefers-reduced-motion: reduce) {
        .hero__video { display: none; }
    }

    .hero__bg-gradient {
        position: absolute;
        inset: 0;
        background:
            radial-gradient(ellipse 80% 60% at 50% 40%, rgba(212, 175, 55, 0.08) 0%, transparent 70%),
            radial-gradient(ellipse 50% 40% at 85% 20%, rgba(212, 175, 55, 0.05) 0%, transparent 50%),
            linear-gradient(180deg, rgba(10,10,10,0.82) 0%, rgba(10,10,10,0.55) 40%, rgba(10,10,10,0.82) 100%);
    }

    /* ─── Bokeh ─── */
    .hero__bokeh {
        position: absolute;
        border-radius: 50%;
        filter: blur(70px);
        opacity: 0;
        will-change: transform, opacity;
        animation: bokehPulse 10s ease-in-out infinite;
    }

    .hero__bokeh--1 {
        width: 350px; height: 350px;
        top: 10%; left: 10%;
        background: radial-gradient(circle, rgba(212,175,55,0.12), transparent 70%);
    }
    .hero__bokeh--2 {
        width: 250px; height: 250px;
        top: 55%; right: 5%;
        background: radial-gradient(circle, rgba(212,175,55,0.08), transparent 70%);
        animation-delay: 2.5s;
    }
    .hero__bokeh--3 {
        width: 200px; height: 200px;
        bottom: 15%; left: 35%;
        background: radial-gradient(circle, rgba(212,175,55,0.08), transparent 70%);
        animation-delay: 5s;
    }
    .hero__bokeh--4 {
        width: 280px; height: 280px;
        top: 25%; right: 25%;
        background: radial-gradient(circle, rgba(255,255,255,0.03), transparent 70%);
        animation-delay: 3.5s;
    }
    .hero__bokeh--5 {
        width: 180px; height: 180px;
        bottom: 30%; right: 15%;
        background: radial-gradient(circle, rgba(212,175,55,0.06), transparent 70%);
        animation-delay: 7s;
    }

    @keyframes bokehPulse {
        0%, 100% { opacity: 0.25; transform: scale(1) translate(0, 0); }
        25%       { opacity: 0.5;  transform: scale(1.1) translate(5px, -5px); }
        50%       { opacity: 0.6;  transform: scale(1.18) translate(-3px, 8px); }
        75%       { opacity: 0.4;  transform: scale(1.05) translate(4px, 3px); }
    }

    /* ─── Particles ─── */
    .hero__particles {
        position: absolute;
        inset: 0;
        z-index: 1;
        pointer-events: none;
        contain: layout style;
    }

    .particle {
        position: absolute;
        border-radius: 50%;
        opacity: 0;
        will-change: transform, opacity;
        animation: particleFloat linear infinite;
    }

    .particle--1  { left: 8%;  bottom: -5%; animation-duration: 14s; animation-delay: 0s;   width: 2px; height: 2px; background: var(--gold-300); }
    .particle--2  { left: 20%; bottom: -5%; animation-duration: 18s; animation-delay: 2s;   width: 3px; height: 3px; background: var(--gold-300); }
    .particle--3  { left: 32%; bottom: -5%; animation-duration: 12s; animation-delay: 4s;   width: 2px; height: 2px; background: var(--silver-200); }
    .particle--4  { left: 44%; bottom: -5%; animation-duration: 16s; animation-delay: 1s;   width: 3px; height: 3px; background: var(--gold-300); }
    .particle--5  { left: 55%; bottom: -5%; animation-duration: 13s; animation-delay: 3s;   width: 2px; height: 2px; background: var(--silver-200); }
    .particle--6  { left: 66%; bottom: -5%; animation-duration: 15s; animation-delay: 5.5s; width: 3px; height: 3px; background: var(--gold-300); }
    .particle--7  { left: 77%; bottom: -5%; animation-duration: 17s; animation-delay: 1.5s; width: 2px; height: 2px; background: var(--gold-300); }
    .particle--8  { left: 88%; bottom: -5%; animation-duration: 14s; animation-delay: 4.5s; width: 3px; height: 3px; background: var(--silver-200); }
    .particle--9  { left: 15%; bottom: -5%; animation-duration: 16s; animation-delay: 6s;   width: 2px; height: 2px; background: var(--gold-300); }
    .particle--10 { left: 50%; bottom: -5%; animation-duration: 13s; animation-delay: 7s;   width: 4px; height: 4px; background: var(--gold-300); }
    .particle--11 { left: 72%; bottom: -5%; animation-duration: 19s; animation-delay: 2.5s; width: 2px; height: 2px; background: var(--silver-200); }
    .particle--12 { left: 38%; bottom: -5%; animation-duration: 15s; animation-delay: 8s;   width: 2px; height: 2px; background: var(--gold-300); }

    @keyframes particleFloat {
        0%   { transform: translateY(0) translateX(0) scale(1);          opacity: 0; }
        8%   {                                                             opacity: 0.9; }
        30%  { transform: translateY(-30vh) translateX(15px) scale(0.8); opacity: 0.5; }
        60%  { transform: translateY(-65vh) translateX(-10px) scale(1.1); opacity: 0.7; }
        100% { transform: translateY(-115vh) translateX(20px) scale(0.6); opacity: 0; }
    }

    /* ─── Content (Centered) ─── */
    .hero__content {
        position: relative;
        z-index: 2;
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        padding-top: 120px;
        padding-bottom: 80px;
        min-height: 100vh;
        justify-content: center;
        max-width: 800px;
    }

    /* ─── Decorative line ─── */
    .hero__card-line {
        width: 60px;
        height: 2px;
        margin-bottom: 2.5rem;
        background: linear-gradient(90deg, transparent, var(--gold-300), transparent);
        transform-origin: center;
        animation: lineSlideIn 1.5s var(--ease-out-expo) both;
        animation-delay: 0.2s;
    }

    @keyframes lineSlideIn {
        from { opacity: 0; transform: scaleX(0); }
        to   { opacity: 1; transform: scaleX(1); }
    }

    .hero__subtitle {
        font-size: 0.85rem;
        font-weight: 500;
        letter-spacing: 0.35em;
        text-transform: uppercase;
        color: var(--gold-300);
        margin-bottom: 1.5rem;
        animation: fadeSlideUp 1.2s var(--ease-out-expo) both;
        animation-delay: 0.4s;
    }

    .hero__title {
        font-family: var(--font-display);
        font-size: clamp(3rem, 6vw, 5.5rem);
        font-weight: 700;
        line-height: 1.1;
        color: var(--white);
        margin-bottom: 1.5rem;
        animation: fadeSlideUp 1.2s var(--ease-out-expo) both;
        animation-delay: 0.6s;
    }

    .hero__tagline {
        font-size: 1rem;
        font-weight: 300;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: var(--silver-200);
        margin-bottom: 2rem;
        border-left: none;
        border-bottom: 1px solid rgba(212, 175, 55, 0.3);
        padding-bottom: 2rem;
        animation: fadeSlideUp 1.2s var(--ease-out-expo) both;
        animation-delay: 0.8s;
    }

    .hero__description {
        font-size: 1.05rem;
        color: var(--silver-100);
        max-width: 560px;
        margin-bottom: 2.5rem;
        line-height: 1.7;
        font-weight: 300;
        opacity: 0.9;
        animation: fadeSlideUp 1.2s var(--ease-out-expo) both;
        animation-delay: 0.9s;
    }

    .hero__actions {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 1.5rem;
        flex-wrap: wrap;
        animation: fadeSlideUp 1.2s var(--ease-out-expo) both;
        animation-delay: 1.1s;
    }

    @keyframes fadeSlideUp {
        from { opacity: 0; transform: translateY(20px); }
        to   { opacity: 1; transform: translateY(0); }
    }

    /* ─── Buttons ─── */
    .hero__btn {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.9rem 2.25rem;
        font-size: 0.78rem;
        font-weight: 600;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        border-radius: 50px;
        transition: all var(--transition-base);
    }

    .hero__btn--primary {
        color: var(--black);
        background: linear-gradient(135deg, var(--gold-300) 0%, var(--gold-400) 100%);
        box-shadow: 0 4px 20px rgba(212, 175, 55, 0.25);
    }
    .hero__btn--primary:hover {
        transform: translateY(-2px) scale(1.03);
        box-shadow: 0 10px 40px rgba(212, 175, 55, 0.4);
    }
    .hero__btn--primary svg { transition: transform var(--transition-base); }
    .hero__btn--primary:hover svg { transform: translateX(5px); }

    .hero__btn--secondary {
        color: var(--white);
        background: rgba(255, 255, 255, 0.06);
        border: 1px solid rgba(255, 255, 255, 0.25);
        backdrop-filter: blur(8px);
    }
    .hero__btn--secondary:hover {
        background: rgba(255, 255, 255, 0.12);
        border-color: rgba(255, 255, 255, 0.4);
        transform: translateY(-2px);
    }

    /* ─── Scroll Indicator ─── */
    .hero__scroll {
        position: absolute;
        bottom: 2rem;
        left: 50%;
        transform: translateX(-50%);
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.5rem;
        z-index: 2;
        animation: fadeSlideUp 1s var(--ease-out-expo) both;
        animation-delay: 1.8s;
    }

    .hero__scroll-text {
        font-size: 0.6rem;
        letter-spacing: 0.25em;
        text-transform: uppercase;
        color: var(--silver-400);
    }

    .hero__scroll-line {
        width: 1px;
        height: 40px;
        background: rgba(255, 255, 255, 0.12);
        position: relative;
        overflow: hidden;
        border-radius: 1px;
    }

    .hero__scroll-dot {
        width: 3px;
        height: 10px;
        background: var(--silver-200);
        border-radius: 3px;
        position: absolute;
        left: -1px;
        animation: scrollDot 2.5s ease-in-out infinite;
    }

    @keyframes scrollDot {
        0%   { top: -10px; opacity: 0; }
        25%  { opacity: 1; }
        100% { top: 40px; opacity: 0; }
    }

    /* ─── Responsive ─── */
    @media (max-width: 768px) {
        .hero__content {
            padding-top: 90px;
            padding-bottom: 60px;
        }

        .hero__title {
            font-size: clamp(2.5rem, 10vw, 3.5rem);
        }

        .hero__actions {
            flex-direction: column;
        }

        .hero__btn {
            width: 100%;
            max-width: 280px;
            justify-content: center;
        }

        .hero__scroll {
            bottom: 1rem;
        }
    }
</style>
